[user]
	name = Ian Draves
	email = 32991131+iandraves@users.noreply.github.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[core]
	editor = vim

[alias]
	co = checkout
	br = branch
	st = status
	lg = log --oneline --graph --decorate -20
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
